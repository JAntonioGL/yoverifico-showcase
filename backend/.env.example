MAIL_REPLY_TO="soporte@yoverifico.com.mx"
MAIL_DRIVER="postmark"
PWDRESET_FROM="yoverifico-security@yoverifico.com.mx"
SECURITY_CONTACT_EMAIL="soporte@yoverifico.com.mx"



