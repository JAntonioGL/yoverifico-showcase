PWD_TICKET_AUDIENCE="yoverifico-pwdreset"
PWD_TICKET_ISSUER="yoverifico"


OTP_MAX_PER_WINDOW="1"
GLOBAL_RATE_WINDOW_MS="60000"
OTP_COOLDOWN_MS="60000"


# OTP para eliminación
