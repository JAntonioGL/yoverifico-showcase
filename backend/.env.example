#configuración de cron para tareas programadas, formato de cron estándar (minuto hora día mes día_semana)
CRON_SCHEDULE = "*/1 * * * *"
CRON_LIBERAR_SCHEDULE="*/10 * * * *"
CRON_PROGRAMAR_MENSUAL="*/1 * * * *"
CRON_SIN_VERIFICACION = "*/30 * * * *"
JWT_AUDIENCE="yoverifico-api"
JWT_ISSUER="yoverifico"
JWT_EXPIRES_IN = "7d"

# Refresh (solo para /auth/refresh)
REFRESH_TTL="180d"
REFRESH_ABSOLUTE_MAX="365d"


#POSTMARK YA NO FUNCIONA PARA ENVÍO DE CORREOS, SE DEBE USAR AZURE COMMUNICATION SERVICES, PERO DEJO LAS VARIABLES POR SI EN EL FUTURO SE QUIERE REVERTIR O USAR POSTMARK PARA OTRAS COSAS
  # (antes 10)
POSTMARK_STREAM="outbound"
