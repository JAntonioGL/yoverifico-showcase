DELETE_TICKET_ISSUER="yoverifico"



# === Planes v2: comportamiento / seguridad ===
PLAN_DEV_VERBOSE_LOG="true"          # En dev muestra logs verbosos
PLAN_DEV_BYPASS_PLAY_VERIFY="false"  # true => NO consulta Play y simula verificación
PLAN_DEV_FAKE_EXPIRY_MIN="120"       # Minutos para expiry simulado cuando bypass=true
PLAN_DEV_FAKE_PRODUCT_ID="suscripcion_plan_plus" #plan que va asubir en modo dave sin playconsole
PLAN_DEV_FAKE_BASE_PLAN_ID=
PLAN_DEV_FAKE_OFFER_ID=

 # Rate limits (por minuto) y cooldown
PLAN_RATE_LIMIT_PER_MIN_UPGRADE="5"        # prod: 5, dev: puedes subir a 999999
PLAN_RATE_LIMIT_PER_MIN_DOWNGRADE="2"      # prod: 2, dev: 999999
PLAN_RATE_LIMIT_PER_MIN_VERIFY="5"         # prod: 5, dev: 999999
PLAN_COOLDOWN_HOURS_AFTER_UPGRADE="24"    # prod: 24, dev: 0

# Resync interno
PLAN_RESYNC_SECRET="SECRETO_REZYNC" # requerido en prod para /resync


RTDN_AUDIENCE="DIRECCION_API_PARA_RTDN_URL" # debe coincidir con --push-auth-token-audience en la configuración de Pub/Sub
# Service Account usada por Pub/Sub para firmar el JWT
RTDN_SA_EMAIL="EXAMPLE@yoverifico.iam.gserviceaccount.com"
# Opcional: bypass local con x-admin-key (solo dev)
RTDN_ALLOW_ADMIN_KEY="true"
ADMIN_API_KEY="ADMIN_KEY_DE_EJEMPLO" # clave secreta para bypass en dev, no la uses en prod

# Debe coincidir con --push-auth-token-audience que configuraste
OIDC_AUDIENCE="AUDIENCIA_PARA_OIDC_URL"
# Emisor esperado para tokens de Google
OIDC_ALLOWED_ISSUERS="https://accounts.google.com"
# La cuenta de servicio que configuraste como push caller
OIDC_ALLOWED_EMAILS="EXAMPLE@yoverifico.iam.gserviceaccount.com"


#ponerlas en dev o prod "production" - "development"
CAPTCHA_BYPASS_WITH_ADMIN_KEY="true"
CAPTCHA_ON_VERIFY="false"
RL_DISABLE="false"
NODE_ENV="development"
RL_BYPASS_WITH_ADMIN_KEY="true"
CAPTCHA_ON_GOOGLE_SIGNUP="false"
CAPTCHA_SIMULATE_PROD="true"     # <- activa verificación real en dev
CAPTCHA_MIN_SCORE="0.1"          # <- umbral “relajado” para emuladores


REDIS_PASS="PASSWORD_DE_REDIS" #reemplaza con tu contraseña de Redis, si no tienes una, déjala vacía
REDIS_HOST="redis"
REDIS_PORT="PUERTO_DE_REDIS" #reemplaza con el puerto de Redis, por defecto es 6379

